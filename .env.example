# ============================================================
# .env.example – Environment variable template
# ============================================================
# 1. Copy this file:  copy .env.example .env
# 2. Fill in your real values below (no quotes needed).
# 3. NEVER commit .env to GitHub – it's in .gitignore.
# ============================================================

# ── Companies House REST API ──────────────────────────────────
# Get a free key at: https://developer.company-information.service.gov.uk/
# Authentication: key is used as HTTP Basic-Auth username; password is blank.
COMPANIES_HOUSE_API_KEY=your_companies_house_api_key_here

# ── Neo4j AuraDB Free ─────────────────────────────────────────
# Find your URI in the AuraDB console: https://console.neo4j.io/
# It looks like: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_aura_password_here